# syntax of loop

DECLARE
  var_counter INT := 0; -- Use a valid data type like NUMBER or INT, and end statement with a semicolon
BEGIN
  WHILE var_counter <= 3 LOOP -- 'WHILE condition LOOP' is the correct syntax
    DBMS_OUTPUT.PUT_LINE('COUNTER IS: ' || var_counter); -- Each statement needs a semicolon
    var_counter := var_counter + 1; -- Manual increment using the assignment operator (:=) and semicolon
  END LOOP; -- 'END LOOP' terminates the loop
END;

