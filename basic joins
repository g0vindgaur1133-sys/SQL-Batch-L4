-- order table's -> customer_id is a foreign key
-- which is connecting to customers table 

-- foreign key refers to the primary key of other table.
-- in the table if we have duplicate values it is a foreign key and the other one is primary key of that table.

select o.orderid, o.pname, o.customerid from orders as o;

select c.customerid, c.name from customers as c;

-- join:-
select o.orderid, o.pname, o.customerid,c.customerid, c.name from orders as o
join customers as c 
where o.customerid=c.customerid;


