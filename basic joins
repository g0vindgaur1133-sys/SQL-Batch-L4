use world;
select * from country;
select * from city;


-- get the city_id , city_name and the countrycode for the city
-- get name,continent,population for each country
-- get the city id, city name, and the countrycode for the each city present in my table


SELECT c.id, c.name, c.countrycode, co.name,co.continent,co.population
FROM city as c
JOIN country as co
where c.countrycode = co.code and co.name in ('south africa', 'afghanistan');



-- you need to find out the countryname and all the language spoken in that country.
select * from countrylanguage;
select * from country;

SELECT c.name, cl.language
FROM country c
JOIN countrylanguage cl
where c.code = cl.countrycode and cl.language in ('english','dutch');


-- we use **on** when we use the inner join

SELECT c.name, cl.language
FROM country c
JOIN countrylanguage cl
on c.code = cl.countrycode and cl.language in ('english','dutch');
